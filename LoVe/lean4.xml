      <item>have</item>
      <item>using</item>
      <item>haveI</item>
      <item>from</item>
      <item>suffices</item>
      <item>nomatch</item>
      <item>nofun</item>
      <item>no_index</item>
      <item>elab</item>
      <item>set_option</item>
      <item>initialize</item>
      <item>builtin_initialize</item>
      <item>example</item>
      <item>inductive_fixpoint</item>
      <item>coinductive_fixpoint</item>
      <item>termination_by</item>
      <item>decreasing_by</item>
      <item>partial_fixpoint</item>
      <item>universe</item>
      <item>variable</item>
      <item>module</item>
      <item>import</item>
      <item>open</item>
      <item>export</item>
      <item>prelude</item>
      <item>renaming</item>
      <item>hiding</item>
      <item>do</item>
      <item>by</item>
      <item>let</item>
      <item>letI</item>
      <item>let_expr</item>
      <item>extends</item>
      <item>mutual</item>
      <item>mut</item>
      <item>where</item>
      <item>rec</item>
      <item>declare_syntax_cat</item>
      <item>syntax</item>
      <item>macro_rules</item>
      <item>macro</item>
      <item>max_prec</item>
      <item>leading_parser</item>
      <item>elab_rules</item>
