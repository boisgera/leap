      <item>throwNamedErrorAt</item>
      <item>throwNamedError</item>
      <item>logNamedWarningAt</item>
      <item>logNamedWarning</item>
      <item>logNamedErrorAt</item>
      <item>logNamedError</item>
      <!-- macro/elaboration %-suffixed forms are handled by regex below
           because they contain % which KDE keyword lists don't support  -->
    </list>

    <!-- ============================================================ -->
    <!-- Contexts                                                       -->
    <!-- ============================================================ -->
    <contexts>

      <!-- Root context -->
      <context name="Normal" attribute="Normal Text" lineEndContext="#stay">

        <!-- ── Comments: most-specific first ── -->
        <StringDetect String="/--" attribute="Documentation Comment" context="DocComment"    lookAhead="false"/>
        <StringDetect String="/-!" attribute="Documentation Comment" context="ModDocComment" lookAhead="false"/>
        <StringDetect String="/-"  attribute="Block Comment"         context="BlockComment"  lookAhead="false"/>
        <StringDetect String="--"  attribute="Line Comment"          context="LineComment"/>

        <!-- ── Guillemet names  «…» ── -->
        <DetectChar char="«" attribute="Entity Name" context="GuillemeName"/>

        <!-- ── Interpolated strings: keyword prefix immediately before " ── -->
        <!-- Handles: s!  m!  throwError  dbg_trace  panic!  reportIssue!
             trace_goal[tag]  trace[tag]                                     -->
        <RegExpr String="(?:s!|m!|throwError|dbg_trace|panic!|reportIssue!|(?:trace_goal|trace)\[[^\]\s]*\])\s*&quot;"
                 attribute="Keyword" context="InterpolatedString"/>

        <!-- ── Regular strings ── -->
        <DetectChar char="&quot;" attribute="String" context="String"/>

        <!-- ── Character literals  'x'  '\n'  '\xNN'  '\uNNNN' ── -->
        <RegExpr String="(?&lt;![_\]\w])'\\(?:x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|[\\&quot;ntr'])'"
                 attribute="Escape" context="#stay"/>
        <RegExpr String="(?&lt;![_\]\w])'[^\\']'"
                 attribute="Char" context="#stay"/>

        <!-- ── Numbers: hex, float, int ── -->
        <RegExpr String="\b0[xX][0-9a-fA-F]+\b"
                 attribute="Hex" context="#stay"/>
        <RegExpr String="\b(?:0|[1-9][0-9]*)(?:\.[0-9]+)?(?:[eE][+-]?[0-9]+)?\b"
                 attribute="Decimal" context="#stay"/>

        <!-- ── #commands ── -->
        <RegExpr String="#(?:print|eval!?|reduce|synth|widget|where|version|with_exporting|check|check_tactic|check_tactic_failure|check_failure|check_simp|discr_tree_key|discr_tree_simp_key|guard|guard_expr|guard_msgs)\b"
                 attribute="Keyword" context="#stay"/>

        <!-- ── deriving instance (two-word keyword) ── -->
        <RegExpr String="\bderiving\s+instance\b" attribute="Keyword" context="#stay"/>

        <!-- ── %-suffixed macro elaboration keywords ── -->
        <RegExpr String="\b(?:binop_lazy|binop|unop|binrel_no_prop|binrel|leftact|rightact|binder_predicate|simproc_pattern|builtin_simproc_pattern|private_decl|type_of|value_of|json|nat_lit|decl_name|exact\?|termination_by\?|by\?|reportIssue)%?\b"
                 attribute="Keyword" context="#stay"/>

        <!-- ── trace/trace_goal with bracket tag ── -->
        <RegExpr String="\b(?:trace_goal|trace)\[[^\]\s]*\]" attribute="Keyword" context="#stay"/>

        <!-- ── attribute[…] and @[…] ── -->
        <RegExpr String="\battribute\b\s*(?:\[[^\]\s]*\]|\[[^\]\s]*)"
                 attribute="Modifier" context="#stay"/>
        <RegExpr String="@(?:\[[^\]\s]*\]|\[[^\]\s]*)"
                 attribute="Modifier" context="#stay"/>

        <!-- ── Boolean constants ── -->
        <keyword String="Constants"  attribute="Constant" context="#stay"/>

        <!-- ── Illegal ── -->
        <keyword String="Illegal"    attribute="Illegal"  context="#stay"/>

        <!-- ── Types ── -->
        <keyword String="Types"      attribute="Type"     context="#stay"/>

        <!-- ── Modifiers ── -->
        <keyword String="Modifiers"  attribute="Modifier" context="#stay"/>

        <!-- ── Definition-introducing keywords → highlight next name ── -->
        <keyword String="DefKeywords" attribute="Definition Keyword" context="AfterDefKeyword"/>

        <!-- ── All other keywords ── -->
        <keyword String="Keywords"   attribute="Keyword"  context="#stay"/>

      </context>

      <!-- ── Line comment ─────────────────────────────────────────── -->
      <context name="LineComment" attribute="Line Comment" lineEndContext="#pop">
      </context>

      <!-- ── Block comment  /- … -/  (nestable) ──────────────────── -->
      <context name="BlockComment" attribute="Block Comment" lineEndContext="#stay">
        <StringDetect String="/-" attribute="Block Comment" context="BlockComment"/>
        <StringDetect String="-/" attribute="Block Comment" context="#pop"/>
      </context>

      <!-- Doc comment  /- - … -/ (documentation) -->
      <context name="DocComment" attribute="Documentation Comment" lineEndContext="#stay">
        <StringDetect String="/-" attribute="Documentation Comment" context="BlockComment"/>
        <StringDetect String="-/" attribute="Documentation Comment" context="#pop"/>
      </context>

      <!-- ── Module doc comment  /-! … -/ ─────────────────────────── -->
      <context name="ModDocComment" attribute="Documentation Comment" lineEndContext="#stay">
        <StringDetect String="/-" attribute="Documentation Comment" context="BlockComment"/>
        <StringDetect String="-/" attribute="Documentation Comment" context="#pop"/>
      </context>

      <!-- ── Guillemet name  «…» ──────────────────────────────────── -->
      <context name="GuillemeName" attribute="Entity Name" lineEndContext="#stay">
        <DetectChar char="»" attribute="Entity Name" context="#pop"/>
      </context>

      <!-- ── Regular double-quoted string ─────────────────────────── -->
      <context name="String" attribute="String" lineEndContext="#stay">
        <RegExpr String="\\[\\&quot;ntr']"     attribute="Escape" context="#stay"/>
        <RegExpr String="\\x[0-9A-Fa-f]{2}"   attribute="Escape" context="#stay"/>
        <RegExpr String="\\u[0-9A-Fa-f]{4}"   attribute="Escape" context="#stay"/>
        <DetectChar char="&quot;" attribute="String" context="#pop"/>
      </context>

      <!-- ── Interpolated string  s!"…{expr}…" ────────────────────── -->
      <!-- We enter here after the opening quote has been consumed      -->
      <context name="InterpolatedString" attribute="String" lineEndContext="#stay">
        <DetectChar char="{" attribute="Keyword" context="Interpolation"/>
        <RegExpr String="\\[\\&quot;ntr']"     attribute="Escape" context="#stay"/>
        <RegExpr String="\\x[0-9A-Fa-f]{2}"   attribute="Escape" context="#stay"/>
        <RegExpr String="\\u[0-9A-Fa-f]{4}"   attribute="Escape" context="#stay"/>
        <DetectChar char="&quot;" attribute="String" context="#pop"/>
      </context>

      <!-- ── Interpolation hole  { … } ─────────────────────────────── -->
      <context name="Interpolation" attribute="Normal Text" lineEndContext="#stay">
        <StringDetect String="/--" attribute="Documentation Comment" context="DocComment"/>
        <StringDetect String="/-!" attribute="Documentation Comment" context="ModDocComment"/>
        <StringDetect String="/-"  attribute="Block Comment"         context="BlockComment"/>
        <StringDetect String="--"  attribute="Line Comment"          context="LineComment"/>
        <DetectChar char="&quot;"  attribute="String"                context="String"/>
        <keyword String="Keywords"    attribute="Keyword"            context="#stay"/>
        <keyword String="DefKeywords" attribute="Definition Keyword" context="#stay"/>
        <keyword String="Types"       attribute="Type"               context="#stay"/>
        <keyword String="Constants"   attribute="Constant"           context="#stay"/>
        <DetectChar char="}" attribute="Keyword" context="#pop"/>
      </context>

      <!-- ── After a definition keyword ───────────────────────────── -->
      <!-- Skip optional whitespace, comments, and a {binder} block,
           then highlight the declared name as Function Name.          -->
      <context name="AfterDefKeyword" attribute="Normal Text" lineEndContext="#pop">
        <RegExpr String="\s+"     attribute="Normal Text"           context="#stay"/>
        <RegExpr String="\{[^}]*\}" attribute="Normal Text"         context="#stay"/>
        <StringDetect String="/--" attribute="Documentation Comment" context="DocComment"/>
        <StringDetect String="/-!" attribute="Documentation Comment" context="ModDocComment"/>
        <StringDetect String="/-"  attribute="Block Comment"         context="BlockComment"/>
        <StringDetect String="--"  attribute="Line Comment"          context="LineComment"/>
        <!-- Guillemet-quoted name -->
        <DetectChar char="«" attribute="Function Name" context="GuillemeFuncName"/>
        <!-- Plain identifier (first char not in the stop-set) -->
        <RegExpr String="[^:«»(){}\[\]\s=→λ∀?][^:«»(){}\[\]\s]*"
                 attribute="Function Name" context="#pop"/>
        <!-- Anything else: bail back to Normal -->
        <RegExpr String="(?=.)" attribute="Normal Text" context="#pop"/>
      </context>

      <!-- ── Guillemet name in definition position ─────────────────── -->
      <context name="GuillemeFuncName" attribute="Function Name" lineEndContext="#stay">
        <DetectChar char="»" attribute="Function Name" context="#pop #pop"/>
      </context>

    </contexts>

    <!-- ============================================================ -->
    <!-- Item data (logical token → default style)                     -->
    <!-- ============================================================ -->
    <itemDatas>
      <itemData name="Normal Text"           defStyleNum="dsNormal"/>
      <itemData name="Line Comment"          defStyleNum="dsLineComment"   italic="true"/>
      <itemData name="Block Comment"         defStyleNum="dsComment"       italic="true"/>
      <itemData name="Documentation Comment" defStyleNum="dsDocumentation" italic="true"/>
      <itemData name="String"                defStyleNum="dsString"/>
      <itemData name="Char"                  defStyleNum="dsChar"/>
      <itemData name="Escape"                defStyleNum="dsSpecialChar"/>
      <itemData name="Decimal"               defStyleNum="dsDecVal"/>
      <itemData name="Hex"                   defStyleNum="dsBaseN"/>
      <itemData name="Constant"              defStyleNum="dsBuiltIn"       bold="false"/>
      <itemData name="Illegal"               defStyleNum="dsError"         bold="true" underline="true"/>
      <itemData name="Type"                  defStyleNum="dsDataType"/>
      <itemData name="Modifier"              defStyleNum="dsAttribute"/>
      <itemData name="Definition Keyword"    defStyleNum="dsKeyword"       bold="true"/>
      <itemData name="Keyword"               defStyleNum="dsKeyword"/>
      <itemData name="Entity Name"           defStyleNum="dsVariable"      italic="true"/>
      <itemData name="Function Name"         defStyleNum="dsFunction"      bold="true"/>
    </itemDatas>

  </highlighting>

  <!-- ============================================================ -->
  <!-- General settings                                              -->
  <!-- ============================================================ -->
  <general>
    <keywords casesensitive="true" weakDeliminator="!?"/>
    <comments>
      <comment name="singleLine" start="--"/>
      <comment name="multiLine"  start="/-" end="-/" region="BlockComment"/>
    </comments>
    <indentation mode="normal"/>
  </general>

</language>