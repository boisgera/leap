<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language SYSTEM "language.dtd">
<!--
  Lean 4 syntax highlighting for Kate / KSyntaxHighlighting / pandoc (skylighting)
  Translated from the official VSCode TextMate grammar:
    https://github.com/leanprover/vscode-lean4/blob/master/vscode-lean4/syntaxes/lean4.json
  License: Apache-2.0
-->
<language name="Lean 4" section="Sources"
          version="1" kateversion="5.0"
          extensions="*.lean"
          mimetype="text/x-lean"
          indentationsensitive="false"
          casesensitive="true"
          author="Translated from leanprover/vscode-lean4"
          license="Apache-2.0">

  <highlighting>

    <!-- ============================================================ -->
    <!-- Keyword lists                                                  -->
    <!-- ============================================================ -->

    <!-- storage.type -->
    <list name="Types">
      <item>Prop</item>
      <item>Type</item>
      <item>Sort</item>
    </list>

    <!-- invalid.illegal -->
    <list name="Illegal">
      <item>sorry</item>
      <item>admit</item>
      <item>#exit</item>
    </list>

    <!-- constant.language -->
    <list name="Constants">
      <item>true</item>
      <item>false</item>
    </list>

    <!-- storage.modifier (bare word forms; attribute[…] and @[…] handled by regex) -->
    <list name="Modifiers">
      <item>local</item>
      <item>scoped</item>
      <item>partial</item>
      <item>unsafe</item>
      <item>nonrec</item>
      <item>public</item>
      <item>private</item>
      <item>protected</item>
      <item>noncomputable</item>
      <item>meta</item>
    </list>

    <!-- Definition-introducing keywords (trigger function-name highlighting) -->
    <list name="DefKeywords">
      <item>inductive</item>
      <item>coinductive</item>
      <item>structure</item>
      <item>theorem</item>
      <item>axiom</item>
      <item>abbrev</item>
      <item>lemma</item>
      <item>def</item>
      <item>instance</item>
      <item>class</item>
    </list>

    <!-- keyword.other (the large flat list from the grammar) -->
